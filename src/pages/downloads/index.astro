---
import Base from "../../layouts/Base.astro";
---

<Base title="Free Reads — Ennea Evolution" description="Two short reads, free. A couple of pieces that do in a few minutes what the whole site is about: help something make sense.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Two short reads, free</p>
      <h1>Take whichever one fits where you are.</h1>
      <p class="lead">A couple of pieces that do in a few minutes what the whole site is about: help something make sense.</p>
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <a class="read-card" href="/downloads/why-you-do-the-thing">
        <p class="read-for">For your own life</p>
        <h3>Why You Do the Thing You Don't Want to Do</h3>
        <p class="read-desc">A short guide to the gap between what you feel and how you act, and why willpower keeps losing to it.</p>
        <span class="arrow-link">Read it <span class="arrow">→</span></span>
      </a>
      <a class="read-card" href="/downloads/the-conversation">
        <p class="read-for">For your team</p>
        <h3>The Conversation Is Rarely the Problem</h3>
        <p class="read-desc">Why good people on good teams keep misreading each other, and one question that prevents more conflict than any communication training.</p>
        <span class="arrow-link">Read it <span class="arrow">→</span></span>
      </a>
    </div>
  </section>
</Base>

<style>
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.25rem, 3vw, 2rem); }
  .read-card {
    display: flex; flex-direction: column;
    background: var(--paper); border: 1px solid var(--line);
    border-top: 4px solid var(--marigold);
    border-radius: var(--radius-lg); padding: clamp(1.6rem, 3vw, 2.4rem);
    box-shadow: var(--shadow-sm); color: var(--body);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .read-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .read-for { font-size: 0.74rem; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 600; color: var(--marigold-600); margin-bottom: 0.6rem; }
  .read-card h3 { color: var(--teal-900); margin-bottom: 0.6rem; }
  .read-desc { flex: 1; margin-bottom: 1rem; }
  @media (max-width: 760px) { .two-col { grid-template-columns: 1fr; } }
</style>
