---
import Base from "../../layouts/Base.astro";

const doors = [
  {
    recognition: "I can't stop worrying.",
    title: "Anxiety & Overthinking",
    line: "Thinking feels safe. Doing feels like a cliff.",
    href: "/personal-work/anxiety-overthinking",
    tint: "#E9F3F1",
    sig: "#56B6B1",
  },
  {
    recognition: "It's such a big decision. I can't decide.",
    title: "Stay or Go",
    line: "A marriage, a faith, a career. The question has been running your life.",
    href: "/personal-work/stay-or-go",
    tint: "#CCD8DE",
    sig: "#2BA1A3",
  },
  {
    recognition: "I lost myself somewhere along the way.",
    title: "Coming Back to Yourself",
    line: "The roles got louder than the person underneath.",
    href: "/personal-work/coming-back-to-yourself",
    tint: "#FFF7E7",
    sig: "#EF9C20",
  },
  {
    recognition: "No matter what I do, it never feels like enough.",
    title: "Confidence & Self-Worth",
    line: "You do plenty. You just don't believe it yet.",
    href: "/personal-work/confidence-self-worth",
    tint: "#F2CFC5",
    sig: "#B22B2E",
  },
  {
    recognition: "I miss someone I love.",
    title: "Love & Grief",
    line: "Right here, or long gone. Still out of reach.",
    href: "/personal-work/love-and-grief",
    tint: "#FEECE6",
    sig: "#9C1B30",
  },
  {
    recognition: "Am I the problem?",
    title: "When You Stop Trusting Yourself",
    line: "People who are the problem rarely ask.",
    href: "/personal-work/am-i-the-problem",
    tint: "#FCE9CD",
    sig: "#D57A27",
  },
];
---

<Base
  title="Personal Work · Ennea Evolution"
  description="Something in your life isn't adding up. Counseling and coaching for people ready to understand their own lives. Start with what feels true."
>
  <!-- PANEL 1 · white · hero, copy only -->
  <section class="panel">
    <div class="container narrow">
      <p class="eyebrow">Personal Work</p>
      <h1>Something in your life isn't adding up.</h1>
      <p class="lead">
        Maybe you can't name it yet. Most people can't. You just know you're anxious, stuck, exhausted, doubting
        yourself, or carrying the same question you've carried for years.
      </p>
      <p>You don't have to have it figured out before you begin. Start with what feels true.</p>
    </div>
  </section>

  <hr class="hairline-gold" />

  <!-- PANEL 2 · white · intro line + clickable card grid, 3 x 2 -->
  <section class="panel">
    <div class="container">
      <h4 class="center" style="max-width:52ch; margin:0 auto 2.5rem;">
        These aren't categories. They're doorways. Start with the one that sounds like your life.
      </h4>
      <div class="grid-3">
        {doors.map((d) => (
          <a href={d.href} class="card washes" style={`--rule:${d.sig}; --wash:${d.tint};`}>
            <p class="recognition">{d.recognition}</p>
            <p class="card-title">{d.title}</p>
            <p style="margin-bottom:0;">{d.line}</p>
            <span class="card-link">This Is Me →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <hr class="hairline-gold" />

  <!-- PANEL 3 · white · centered standalone line -->
  <section class="panel center">
    <div class="container narrow">
      <blockquote class="pullquote" style="--accent:var(--teal); margin-inline:auto;">
        You don't have to choose the perfect door. They all open into the same room, and I'll meet you there.
      </blockquote>
      <p style="margin-bottom:0;">We'll start with whatever is loudest today and follow it wherever it leads.</p>
    </div>
  </section>

  <!-- PANEL 4 · tint #FFF7E7 · single column -->
  <section class="panel tint-band" style="--tint:#FFF7E7;">
    <div class="container narrow">
      <h3>You get yourself back.</h3>
      <p>Most people come in wanting relief from the anxiety, the relationship, the decision, the self-doubt. What they usually get back is themselves.</p>
      <p>You stop arguing with yourself. You stop treating every decision like a verdict on your worth. You stop carrying relationships alone. You begin responding to what's actually happening, instead of what fear has convinced you is true.</p>
      <p>Life starts making sense in a way it never quite has before.</p>
      <blockquote class="pullquote testimonial" style="--accent:var(--teal);">
        "Everything makes sense now. I know what to do. And I feel capable of doing it."
        <cite>A client</cite>
      </blockquote>
      <p>That's the moment we're after.</p>
    </div>
  </section>

  <!-- PANEL 5 · white · 50/50 split: copy left, photo right -->
  <section class="panel">
    <div class="container split">
      <div>
        <h3>Ready to begin?</h3>
        <p>Choose the door that feels most like you. If you're still not sure, we'll figure it out together.</p>
        <a href="/get-started" class="btn" style="margin-block:0.5rem 1.75rem;">Get Started</a>
        <p style="margin-bottom:0.2rem;"><strong>Two short reads, freely offered</strong></p>
        <p style="margin-bottom:0;">A few minutes each. A small taste of the work.</p>
      </div>
      <div class="photo-block" style="--block:#FFF7E7;">
        <div class="photo">
          <img src="/img/quiet-kitchen.jpg" alt="A warm kitchen table in real morning window light" width="960" height="640" loading="lazy" />
        </div>
      </div>
    </div>
  </section>
</Base>
