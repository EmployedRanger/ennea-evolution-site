---
import Base from "./Base.astro";
const {
  eyebrow = "Personal Work",
  title,
  lead,
  metaTitle,
  metaDescription,
  startHeading = "Start here",
  start,
  ctaLabel = "Get Started",
  ctaHref = "/get-started",
} = Astro.props;
---

<Base title={metaTitle ?? `${title} · Ennea Evolution`} description={metaDescription ?? lead}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      {lead && <p class="lead">{lead}</p>}
    </div>
  </section>

  <section class="section">
    <div class="container narrow prose">
      <slot />
    </div>
  </section>

  <section class="section bg-teal center start-cta">
    <div class="container narrow">
      <p class="eyebrow">{startHeading}</p>
      {start && <p class="start-text">{start}</p>}
      <slot name="start-extra" />
      <div class="btn-row" style="justify-content:center; margin-top:1.5rem;">
        <a href={ctaHref} class="btn btn-primary">{ctaLabel}</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .start-cta h2 { max-width: 24ch; margin-inline: auto; }
  .start-text { color: #cfe0e2; max-width: 60ch; margin-inline: auto; }
  .start-cta :global(.start-text + .start-text) { margin-top: 1rem; }
</style>
