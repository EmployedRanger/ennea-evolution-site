---
import EnneagramMark from "./EnneagramMark.astro";
import NineDots from "./NineDots.astro";
---
<footer class="footer">
  <div class="container">
    <div class="foot-brand">
      <span class="mark"><EnneagramMark size={40} /></span>
      <div>
        <p class="wordmark">Ennea Evolution</p>
        <p class="thesis">People make sense.</p>
      </div>
    </div>

    <nav class="foot-nav" aria-label="Footer">
      <a href="/">Home</a>
      <a href="/personal-work">Personal Work</a>
      <a href="/professional-work">Professional Work</a>
      <a href="/enneagram">The Enneagram</a>
      <a href="/about">About</a>
      <a href="/get-started">Get Started</a>
    </nav>

    <p class="contact">
      <a href="mailto:enneaevolution@gmail.com">enneaevolution@gmail.com</a> · <a href="tel:+14358810193">435-881-0193</a> · Cache Valley, Utah
    </p>

    <div class="dots"><NineDots /></div>

    <p class="crisis">
      This website and my services are not crisis care. If you are in crisis or thinking about harming yourself,
      please reach out right now: call or text 988 to reach the Suicide &amp; Crisis Lifeline, available 24 hours
      a day, or call 911.
    </p>
  </div>
</footer>

<style>
  .footer {
    background: var(--teal);
    color: #ffffff;
    padding-block: clamp(2.75rem, 6vw, 4.5rem) 2rem;
  }
  .foot-brand { display: flex; align-items: center; gap: 1rem; justify-content: center; margin-bottom: 1.75rem; }
  .mark { color: #ffffff; opacity: 0.9; flex-shrink: 0; }
  .wordmark { font-family: var(--serif); font-size: 1.45rem; margin: 0; line-height: 1.2; }
  .thesis { margin: 0; font-size: 0.95rem; opacity: 0.85; }

  .foot-nav { display: flex; flex-wrap: wrap; gap: 0.4rem 1.6rem; justify-content: center; margin-bottom: 1.4rem; }
  .foot-nav a { color: #ffffff; font-weight: 550; font-size: 0.95rem; }
  .foot-nav a:hover { color: #ffffff; }

  .contact { text-align: center; font-size: 0.95rem; margin-bottom: 1.6rem; }
  .contact a { color: #ffffff; }

  .dots { margin-bottom: 1.6rem; }

  .crisis {
    max-width: 62ch;
    margin: 0 auto;
    text-align: center;
    font-size: 0.88rem;
    font-style: italic;
    line-height: 1.6;
    color: #ffffff;
    opacity: 0.95;
  }
</style>
