<svg class="ee-diagram" role="img" aria-label="A balance beam resting perfectly level between stay and go, with what you actually feel sitting underneath it, never placed on the scale." preserveAspectRatio="xMidYMid meet" viewBox="0 0 620 420" xmlns="http://www.w3.org/2000/svg">
  <!-- caption -->
  <text x="310" y="52" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="21" font-style="italic" fill="#16323a">It comes out even. Every time.</text>
  <!-- beam, perfectly level -->
  <rect x="120" y="143" width="380" height="13" rx="6.5" fill="#155f73"/>
  <!-- hangers -->
  <line x1="165" y1="150" x2="165" y2="205" stroke="#155f73" stroke-width="2.5"/>
  <line x1="455" y1="150" x2="455" y2="205" stroke="#155f73" stroke-width="2.5"/>
  <!-- pans -->
  <path d="M133 205 Q165 236 197 205" fill="none" stroke="#155f73" stroke-width="3"/>
  <path d="M423 205 Q455 236 487 205" fill="none" stroke="#155f73" stroke-width="3"/>
  <!-- chips resting in the pans -->
  <rect x="129" y="176" width="72" height="30" rx="8" fill="#e9f1f2" stroke="#155f73" stroke-width="2"/>
  <text x="165" y="196" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="15" font-weight="700" letter-spacing="1.5" fill="#155f73">STAY</text>
  <rect x="419" y="176" width="72" height="30" rx="8" fill="#e9f1f2" stroke="#155f73" stroke-width="2"/>
  <text x="455" y="196" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="15" font-weight="700" letter-spacing="1.5" fill="#155f73">GO</text>
  <!-- fulcrum -->
  <polygon points="310,157 282,212 338,212" fill="#0e3c49"/>
  <!-- arrow up from the missing weight to the fulcrum -->
  <line x1="310" y1="260" x2="310" y2="218" stroke="#155f73" stroke-width="3"/>
  <polygon points="310,210 302,226 318,226" fill="#155f73"/>
  <!-- the weight that never gets placed on the scale -->
  <rect x="175" y="262" width="270" height="86" rx="14" fill="#155f73"/>
  <text x="310" y="296" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="13" font-weight="700" letter-spacing="1.4" fill="#ffffff">WHAT YOU ACTUALLY FEEL</text>
  <text x="310" y="322" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="14" font-style="italic" fill="#cfe2e4">the part the arguments keep talking over</text>
  <!-- takeaway -->
  <text x="310" y="388" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="13" font-weight="700" letter-spacing="1.6" fill="#155f73">THE DEADLOCK ISN'T MADE OF FACTS</text>
</svg>
