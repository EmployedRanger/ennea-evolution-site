<svg class="ee-diagram" role="img" aria-label="A set of volume bars: the roles are turned up loud, while you is turned almost all the way down. The dashed outline shows the volume that got lost. They all run on the same dial." preserveAspectRatio="xMidYMid meet" viewBox="0 0 620 400" xmlns="http://www.w3.org/2000/svg">
  <!-- eyebrow -->
  <text x="310" y="34" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="13" font-weight="700" letter-spacing="1.4" fill="#6d7c80">THE ROLES GOT LOUDER THAN THE PERSON UNDERNEATH</text>
  <!-- baseline -->
  <line x1="40" y1="322" x2="580" y2="322" stroke="#d8cdb8" stroke-width="2"/>
  <!-- loud role bars -->
  <rect x="56" y="100" width="78" height="222" rx="9" fill="#155f73"/>
  <rect x="161" y="82" width="78" height="240" rx="9" fill="#155f73"/>
  <rect x="266" y="112" width="78" height="210" rx="9" fill="#155f73"/>
  <rect x="371" y="92" width="78" height="230" rx="9" fill="#155f73"/>
  <!-- the "you" bar: the dashed outline is the volume that got turned down -->
  <rect x="481" y="96" width="78" height="226" rx="9" fill="none" stroke="#155f73" stroke-width="2" stroke-dasharray="6 5"/>
  <rect x="481" y="262" width="78" height="60" rx="9" fill="#e9f1f2" stroke="#155f73" stroke-width="2.5"/>
  <text x="520" y="170" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="12.5" font-style="italic" fill="#6d7c80">where the</text>
  <text x="520" y="187" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="12.5" font-style="italic" fill="#6d7c80">volume used</text>
  <text x="520" y="204" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="12.5" font-style="italic" fill="#6d7c80">to be</text>
  <!-- labels -->
  <g font-family="Figtree, system-ui, sans-serif" font-size="12" font-weight="700" letter-spacing="1" fill="#155f73" text-anchor="middle">
    <text x="95" y="344">SPOUSE</text>
    <text x="200" y="344">PARENT</text>
    <text x="305" y="344">EMPLOYEE</text>
    <text x="410" y="344">RESPONSIBLE</text>
    <text x="520" y="344">YOU</text>
  </g>
  <text x="520" y="362" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="12.5" font-style="italic" fill="#6d7c80">your aliveness</text>
  <!-- takeaway -->
  <text x="262" y="388" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="13" font-weight="700" letter-spacing="1.6" fill="#155f73">THEY ALL RUN ON THE SAME DIAL</text>
</svg>
