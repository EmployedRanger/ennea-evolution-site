<svg class="ee-diagram" role="img" aria-label="Two overlapping figures: the person who is actually there, and your version of them. The gap between is the misreading." preserveAspectRatio="xMidYMid meet" viewBox="0 0 560 412" xmlns="http://www.w3.org/2000/svg">
  <!-- figure A : the person (solid) -->
  <path d="M96 300 L114 182 Q122 150 160 142 L240 142 Q278 150 286 182 L304 300 Z" fill="#155f73"/>
  <circle cx="200" cy="86" r="46" fill="#155f73"/>
