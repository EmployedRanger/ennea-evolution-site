  <!-- labels -->
  <text x="200" y="356" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="14.4" font-weight="700" letter-spacing="1.4" fill="#155f73">THE PERSON</text>
  <text x="200" y="378" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="11.2" fill="#3f5258">who is actually there</text>
  <text x="360" y="392" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="14.4" font-weight="700" letter-spacing="1.4" fill="#155f73">YOUR VERSION OF THEM</text>
  <text x="360" y="412" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="11.2" fill="#3f5258">the one you actually respond to</text>
</svg>
