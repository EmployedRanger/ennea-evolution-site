  <line x1="246" y1="74" x2="276" y2="64" stroke="#9aa7ab" stroke-width="2" stroke-dasharray="3 3"/>
  <text x="261" y="40" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="11.7" font-style="italic" fill="#6d7c80">the gap</text>
  <text x="261" y="56" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="9.9" fill="#6d7c80">is the misreading</text>
