<svg class="ee-diagram" role="img" aria-label="One photograph, and three different stories already formed about it." preserveAspectRatio="xMidYMid meet" viewBox="0 0 600 380" xmlns="http://www.w3.org/2000/svg">
  <!-- the photograph -->
  <rect x="16" y="96" width="214" height="180" rx="8" fill="#e9f1f2" stroke="#155f73" stroke-width="2.6"/>
  <!-- minimal desk scene inside -->
  <line x1="48" y1="232" x2="198" y2="232" stroke="#155f73" stroke-width="3"/>
  <line x1="70" y1="232" x2="70" y2="262" stroke="#155f73" stroke-width="3"/>
  <line x1="176" y1="232" x2="176" y2="262" stroke="#155f73" stroke-width="3"/>
  <circle cx="123" cy="150" r="22" fill="none" stroke="#155f73" stroke-width="3"/>
  <path d="M92 210 Q92 174 123 174 Q154 174 154 210 Z" fill="none" stroke="#155f73" stroke-width="3"/>
  <rect x="150" y="196" width="36" height="26" rx="3" fill="none" stroke="#155f73" stroke-width="3"/>
  <text x="123" y="306" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="12.6" font-weight="700" letter-spacing="1.2" fill="#155f73">ONE PHOTOGRAPH</text>
  <text x="123" y="326" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.8" fill="#3f5258">the same few seconds</text>
  <!-- arrows fanning out -->
  <path d="M236 150 Q318 96 372 70" fill="none" stroke="#9aa7ab" stroke-width="2.4"/>
  <polygon points="380,66 365,63 369,77" fill="#9aa7ab"/>
  <path d="M236 186 L372 186" fill="none" stroke="#9aa7ab" stroke-width="2.4"/>
  <polygon points="380,186 367,180 367,192" fill="#9aa7ab"/>
  <path d="M236 222 Q318 276 372 302" fill="none" stroke="#9aa7ab" stroke-width="2.4"/>
  <polygon points="380,306 369,295 365,309" fill="#9aa7ab"/>
  <!-- three readings -->
  <rect x="384" y="40" width="200" height="62" rx="8" fill="#ffffff" stroke="#155f73" stroke-width="2.4"/>
  <text x="484" y="69" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="16.2" font-weight="700" fill="#155f73">“Focused.”</text>
  <text x="484" y="89" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.3" fill="#3f5258">someone in deep work</text>
  <rect x="384" y="155" width="200" height="62" rx="8" fill="#ffffff" stroke="#155f73" stroke-width="2.4"/>
  <text x="484" y="184" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="16.2" font-weight="700" fill="#155f73">“Checked out.”</text>
  <text x="484" y="204" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.3" fill="#3f5258">someone who has given up</text>
  <rect x="384" y="270" width="200" height="62" rx="8" fill="#ffffff" stroke="#155f73" stroke-width="2.4"/>
  <text x="484" y="299" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="16.2" font-weight="700" fill="#155f73">“Exhausted.”</text>
  <text x="484" y="319" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.3" fill="#3f5258">someone running on empty</text>
  <text x="484" y="356" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="11.7" font-weight="700" letter-spacing="1.2" fill="#155f73">THREE STORIES, ALREADY FORMED</text>
</svg>
