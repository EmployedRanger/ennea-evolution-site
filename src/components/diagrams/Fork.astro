  <polygon points="246,180 234,173.5 234,186.5" fill="#9aa7ab"/>
  <path d="M446 148 Q 496 92 510 71" fill="none" stroke="#155f73" stroke-width="3"/>
  <polygon points="522,70 510,63.5 510,76.5" fill="#155f73"/>
  <path d="M446 212 Q 496 268 510 289" fill="none" stroke="#b1543f" stroke-width="3" stroke-dasharray="5 4"/>
  <polygon points="522,290 510,283.5 510,296.5" fill="#b1543f"/>
  <rect x="14" y="138" width="156" height="84" rx="11" fill="#ffffff" stroke="#d8cdb8" stroke-width="2"/>
  <text x="92" y="173" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="13.5" font-weight="700" letter-spacing="1.6" fill="#3f5258">INCIDENT</text>
  <text x="92" y="195" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.8" fill="#3f5258">Something happens.</text>
  <rect x="246" y="110" width="200" height="140" rx="12" fill="#e9f1f2" stroke="#155f73" stroke-width="2.6"/>
  <text x="346" y="150" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="13.5" font-weight="700" letter-spacing="1.6" fill="#155f73">THE SENSE</text>
  <text x="346" y="176" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.8" fill="#16323a">A quiet flicker that there</text>
  <text x="346" y="193" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.8" fill="#16323a">may be more here than the</text>
  <text x="346" y="210" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.8" fill="#16323a">story alone would say.</text>
  <rect x="522" y="22" width="146" height="96" rx="11" fill="#155f73" stroke="#155f73" stroke-width="2"/>
  <text x="595" y="58" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="13.5" font-weight="700" letter-spacing="1.6" fill="#ffffff">CONNECT</text>
  <text x="595" y="80" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.8" fill="#eef5f6">Follow the sense</text>
  <text x="595" y="96" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.8" fill="#eef5f6">toward the person.</text>
  <rect x="522" y="242" width="146" height="96" rx="11" fill="#ffffff" stroke="#b1543f" stroke-width="2" stroke-dasharray="5 4"/>
  <text x="595" y="278" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="13.5" font-weight="700" letter-spacing="1.6" fill="#b1543f">DISMISS</text>
  <text x="595" y="300" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.8" fill="#3f5258">Set the sense down.</text>
  <text x="595" y="316" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.8" fill="#3f5258">Let the story take over.</text>
</svg>
