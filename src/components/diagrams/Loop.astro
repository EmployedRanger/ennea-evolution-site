  <path d="M439.75 283.14 A170 170 0 0 1 386.98 357.12" fill="none" stroke="#155f73" stroke-width="2.6"/>
  <path d="M173.02 357.12 A170 170 0 0 1 120.25 283.14" fill="none" stroke="#155f73" stroke-width="2.6"/>
  <path d="M120.25 166.86 A170 170 0 0 1 173.02 92.88" fill="none" stroke="#155f73" stroke-width="2.6"/>
  <polygon points="439.75,166.86 426.29,154.73 442.27,148.91" fill="#155f73"/>
  <polygon points="386.98,357.12 394.06,340.44 404.76,353.66" fill="#155f73"/>
  <polygon points="120.25,283.14 133.71,295.27 117.73,301.09" fill="#155f73"/>
  <polygon points="173.02,92.88 165.94,109.56 155.24,96.34" fill="#155f73"/>
  <text x="280" y="217" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="24.3" font-weight="700" fill="#155f73">The</text>
  <text x="280" y="247" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="24.3" font-weight="700" fill="#155f73">Loop</text>
  <rect x="182" y="9" width="196" height="92" rx="11" fill="#ffffff" stroke="#155f73" stroke-width="2.4"/>
  <text x="280" y="44" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="12.6" font-weight="700" letter-spacing="1.6" fill="#155f73">INCIDENT</text>
  <text x="280" y="66" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.3" fill="#3f5258">What actually happened.</text>
  <text x="280" y="83" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.3" fill="#3f5258">Only the fact.</text>
  <rect x="352" y="179" width="196" height="92" rx="11" fill="#ffffff" stroke="#155f73" stroke-width="2.4"/>
  <text x="450" y="214" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="12.6" font-weight="700" letter-spacing="1.6" fill="#155f73">INTERPRETATION</text>
  <text x="450" y="236" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.3" fill="#3f5258">The story we begin</text>
  <text x="450" y="253" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.3" fill="#3f5258">to tell about it.</text>
  <rect x="182" y="349" width="196" height="92" rx="11" fill="#ffffff" stroke="#155f73" stroke-width="2.4"/>
  <text x="280" y="384" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="12.6" font-weight="700" letter-spacing="1.6" fill="#155f73">INTENT</text>
  <text x="280" y="406" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.3" fill="#3f5258">The reason we assign.</text>
  <text x="280" y="423" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.3" fill="#3f5258">We decide their why.</text>
  <rect x="12" y="179" width="196" height="92" rx="11" fill="#ffffff" stroke="#155f73" stroke-width="2.4"/>
  <text x="110" y="214" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="12.6" font-weight="700" letter-spacing="1.6" fill="#155f73">REACTION</text>
  <text x="110" y="236" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.3" fill="#3f5258">What we do,</text>
  <text x="110" y="253" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.3" fill="#3f5258">based on the story.</text>
</svg>
