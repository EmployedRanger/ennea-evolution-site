<svg class="ee-diagram" role="img" aria-label="A behavior, they went quiet in the meeting, then your locked-in first read versus other things that could be true." preserveAspectRatio="xMidYMid meet" viewBox="0 0 602 384" xmlns="http://www.w3.org/2000/svg">
  <!-- behavior -->
  <rect x="16" y="146" width="186" height="100" rx="9" fill="#e9f1f2" stroke="#155f73" stroke-width="2.6"/>
  <text x="109" y="177" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="11.2" font-weight="700" letter-spacing="1.3" fill="#155f73">THE BEHAVIOR</text>
  <text x="109" y="202" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="13.5" fill="#16323a">They went quiet</text>
  <text x="109" y="223" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="13.5" fill="#16323a">in the meeting.</text>
  <!-- arrow to first read (solid) -->
  <path d="M202 172 Q300 96 372 84" fill="none" stroke="#155f73" stroke-width="3"/>
  <polygon points="384,82 369,79 373,93" fill="#155f73"/>
  <!-- first read : the locked-in single interpretation, in brand red -->
  <rect x="386" y="44" width="200" height="84" rx="9" fill="#b1543f"/>
  <text x="486" y="76" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.3" font-weight="700" letter-spacing="1.3" fill="#f1ded7">YOUR FIRST READ</text>
  <text x="486" y="103" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="14.0" fill="#ffffff">“They have checked out.”</text>
  <!-- arrow to alternatives (dashed) -->
  <path d="M202 224 Q300 280 372 286" fill="none" stroke="#6d7c80" stroke-width="2.6" stroke-dasharray="6 5"/>
  <polygon points="384,287 370,279 371,293" fill="#6d7c80"/>
  <text x="486" y="166" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="11.2" font-weight="700" letter-spacing="1.2" fill="#155f73">WHAT ELSE COULD BE TRUE?</text>
  <rect x="386" y="180" width="200" height="56" rx="8" fill="#ffffff" stroke="#155f73" stroke-width="2.2" stroke-dasharray="6 5"/>
  <text x="486" y="213" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="12.2" fill="#0e3c49">They are protecting their focus.</text>
  <rect x="386" y="244" width="200" height="56" rx="8" fill="#ffffff" stroke="#155f73" stroke-width="2.2" stroke-dasharray="6 5"/>
  <text x="486" y="277" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="12.2" fill="#0e3c49">They are thinking it through.</text>
  <rect x="386" y="308" width="200" height="56" rx="8" fill="#ffffff" stroke="#155f73" stroke-width="2.2" stroke-dasharray="6 5"/>
  <text x="486" y="341" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="12.2" fill="#0e3c49">Something off-screen is pulling.</text>
</svg>
