<svg class="ee-diagram" role="img" aria-label="A paneled door labeled the story you are protecting, beside the questions it lets you not ask." preserveAspectRatio="xMidYMid meet" viewBox="0 0 580 384" xmlns="http://www.w3.org/2000/svg">
  <text x="151" y="40" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.8" font-weight="700" letter-spacing="1.1" fill="#6d7c80">THE QUESTIONS IT LETS YOU NOT ASK</text>
  <g>
    <rect x="22" y="60" width="266" height="60" rx="7" fill="#f4ede0" stroke="#d8cdb8" stroke-width="2" stroke-dasharray="5 4"/>
    <text x="155" y="96" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="13.1" font-style="italic" fill="#6d7c80">Did I handle this well?</text>
