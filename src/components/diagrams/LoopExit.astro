  <rect x="412" y="78" width="158" height="86" rx="9" fill="#155f73"/>
  <text x="491" y="114" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="18.0" font-weight="700" fill="#ffffff">Self-Aware</text>
  <text x="491" y="138" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="10.3" fill="#cfe2e4">the way out of the loop</text>
</svg>
