<svg class="ee-diagram" role="img" aria-label="The self-conscious loop, and the exit ramp out to self-aware." preserveAspectRatio="xMidYMid meet" viewBox="0 0 582 380" xmlns="http://www.w3.org/2000/svg">
  <!-- the loop : three clockwise arcs -->
  <path d="M300.1 149.5 A118 118 0 0 1 220.5 328.2" fill="none" stroke="#155f73" stroke-width="3"/>
  <path d="M220.5 328.2 A118 118 0 0 1 89.1 171.6" fill="none" stroke="#155f73" stroke-width="3"/>
  <path d="M89.1 171.6 A118 118 0 0 1 224.5 96.6" fill="none" stroke="#155f73" stroke-width="3"/>
  <polygon points="220.5,328.2 232.9,317.9 235.7,333.7" fill="#155f73"/>
  <polygon points="89.1,171.6 91.8,187.5 76.8,182.1" fill="#155f73"/>
  <polygon points="224.5,96.6 209.1,101.5 212.5,85.9" fill="#155f73"/>
  <text x="200" y="200" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="19.8" font-weight="700" fill="#155f73">Self-Conscious</text>
  <text x="200" y="226" text-anchor="middle" font-family="Figtree, system-ui, sans-serif" font-size="11.2" fill="#3f5258">watching how you appear</text>
