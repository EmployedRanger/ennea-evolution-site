---
// Nine-dot divider: nine small circles in the nine signature colors,
// ordered 8, 9, 1, 2, 3, 4, 5, 6, 7 so the three color families cluster.
const colors = [
  "#038A96", "#2BA1A3", "#56B6B1", // Body
  "#9C1B30", "#B22B2E", "#E63E30", // Heart
  "#FFC62C", "#EF9C20", "#D57A27", // Head
];
---
<div class="ninedots" aria-hidden="true">
  {colors.map((c) => <i style={`background:${c}`}></i>)}
</div>
